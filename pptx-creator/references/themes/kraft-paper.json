    "kicker": {
      "fontFace": "Courier New",
      "fontSize": 18,
      "bold": true,
      "allCaps": true
    },
    "meta": {
      "fontFace": "Verdana",
      "fontSize": 14
    },
    "minBodyFontSize": 18
  },
  "spacing": {
    "lineHeight": 1.4,
